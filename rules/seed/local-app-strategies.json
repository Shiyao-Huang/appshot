{
  "schemaVersion": 2,
  "description": "AppShot rule training catalog. Agents edit this JSON or call `appshot rules upsert/patch`; the trainer interprets JSON rules and does not hard-code app strategies. OCR is a teacher/evaluator signal by default, not a rule output source.",
  "trainingDefaults": {
    "ocrPolicy": "teacher-only",
    "selectionMode": "accessibility-first",
    "teacherSources": ["ocr", "visible", "accessibility", "document"],
    "anchorSourceOrder": ["visible", "accessibility", "document", "ocr"],
    "anchorSourceCaps": {
      "visible": 8,
      "accessibility": 8,
      "document": 8,
      "ocr": 6
    },
    "ocrAnchorQuality": {
      "minLength": 6,
      "minContentRatio": 0.45,
      "minLetterOrCJKCount": 4,
      "maxSingleCharacterTokens": 3
    },
    "anchorRejectRegex": [
      "^\\d+(?:\\.\\d+)?\\s*(?:KB|MB|GB|TB)$",
      "^\\d{4}年\\d{1,2}月\\d{1,2}日\\s+\\d{1,2}:\\d{2}$",
      "^(昨天|前天)\\s+\\d{1,2}:\\d{2}$",
      "^今天\\s+\\d{1,2}:\\d{2}$",
      "^\\d+\\s*字节$",
      "^在iCloud中$",
      "^选择了\\d+项（共\\d+项），.*可用$",
      "^_NS:\\d+$",
      "^，?已持续\\s+(?:\\d+m\\s+)?\\d+s$",
      "^/image\\?resource_type=image",
      "^\"value\":\\s+\"[A-Za-z0-9+/=]{40,}",
      "^command:workbench\\.",
      "^主体内容$",
      "^Add file:.* to context$",
      "^Send \\[.*\\] Send to New Chat",
      "^Hide (?:Secondary Side Bar|Panel)",
      "^Maximize (?:Secondary Side Bar|Panel)$",
      "^Open Customizations$",
      "^Add Context\\.\\.\\.",
      "^Split Editor",
      "^Claude Code: Open$",
      "^(Configure Tools\\.\\.\\.|New Chat \\(⌘N\\)|Previous tip|Disable tips|Dismiss tip|Next tip)$",
      "^(scroll area|form)$",
      "^[─━—\\-]{12,}.*$"
    ],
    "densityFloor": 0.02,
    "captureArgs": [
      "--max-depth",
      "${capture.maxDepth}",
      "--max-children",
      "${capture.maxChildren}",
      "--accessibility-timeout",
      "${capture.accessibilityTimeout}",
      "--screenshot-timeout",
      "${capture.screenshotTimeout}",
      "--include-screenshot",
      "--include-ocr",
      "--screenshot",
      "${paths.screenshot}",
      "--output",
      "${paths.raw}",
      "--pretty"
    ],
    "metricWeights": {
      "weightedVisualRecall": 0.55,
      "anchorRecall": 0.25,
      "informationDensity": 0.2
    }
  },
  "ruleTemplate": {
    "id": "${variant.id}",
    "scope": "app",
    "bucket": "${bucket.bucketID}",
    "strategy": "${variant.strategy}",
    "match": {
      "appBundleIds": "${bucket.appBundleIDs}",
      "windowTitleRegex": ".*",
      "treeRegex": "${bucket.treeRegex}",
      "pathRegex": "accessibility\\.root|accessibility\\.visibleText|accessibility\\.text|documentReferences|codexBrowserDOMIntegration|codexElectronRemoteDebugging"
    },
    "action": {
      "includeChildren": true,
      "sources": "${variant.sources}",
      "ocrPolicy": "teacher-only",
      "promoteTextKeys": [
        "textContent",
        "value",
        "description",
        "title",
        "visibleTextFragments"
      ],
      "keepRegex": [
        ".{4,}"
      ],
      "dropRegex": [
        "^\\s*$"
      ],
      "fallbackOCR": false,
      "transport": {
        "format": "toon",
        "maxImportantLines": "${variant.maxImportantLines}",
        "maxRichLines": "${variant.maxRichLines}",
        "preserveRaw": true
      }
    },
    "priority": "${variant.priority}",
    "confidence": 0.65,
    "enabled": true
  },
  "focusBundles": [
    "com.apple.Safari",
    "com.apple.Terminal",
    "com.apple.dt.Xcode",
    "com.apple.finder",
    "com.electron.lark",
